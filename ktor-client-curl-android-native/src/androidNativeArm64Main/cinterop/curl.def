package = libcurl
headerFilter = curl/*
headers = curl/curl.h \
          curl/curlver.h \
          curl/easy.h \
          curl/header.h \
          curl/mprintf.h \
          curl/multi.h \
          curl/stdcheaders.h \
          curl/system.h \
          curl/urlapi.h \
          curl/websockets.h